   >
  <text xmlns="https://www.latex-project.org/ns/dflt"
     id="ID.00006"
     xmlns:Layout="http://iso.org/pdf/ssn/Layout"
     Layout:TextAlign="Justify"
     rolemaps-to="P"
    >
   <?MarkedContent page="1" ?>המאמר השני
  </text>
 </text-unit>
 <text-unit xmlns="https://www.latex-project.org/ns/dflt"
    id="ID.00007"
    rolemaps-to="Part"
   >
  <text xmlns="https://www.latex-project.org/ns/dflt"
     id="ID.00008"
     xmlns:Layout="http://iso.org/pdf/ssn/Layout"
     Layout:TextAlign="Justify"
     rolemaps-to="P"
    >
   <?MarkedContent page="1" ?>בפנות התוריות, ר״ל שהם יסודות ועמודים 
   <?MarkedContent page="1" ?>אשר בית אלהים נכון עליהם, ובמציאותם יציר 
   <?MarkedContent page="1" ?>מציאות התורה מסדרת ממנו יתברך, ואלו יציר 
   <?MarkedContent page="1" ?>העדר אחת מהם תפל התורה בכללה חלילה.
  </text>
 </text-unit>
 <text-unit xmlns="https://www.latex-project.org/ns/dflt"
    id="ID.00009"
    rolemaps-to="Part"
   >
  <text xmlns="https://www.latex-project.org/ns/dflt"
     id="ID.00010"
     xmlns:Layout="http://iso.org/pdf/ssn/Layout"
     Layout:TextAlign="Justify"
     rolemaps-to="P"
    >
   <?MarkedContent page="1" ?>Трактат Второй
  </text>
 </text-unit>
 <text-unit xmlns="https://www.latex-project.org/ns/dflt"
    id="ID.00011"
    rolemaps-to="Part"
   >
  <text xmlns="https://www.latex-project.org/ns/dflt"
     id="ID.00012"
     xmlns:Layout="http://iso.org/pdf/ssn/Layout"
     Layout:TextAlign="Justify"
     rolemaps-to="P"
    >
   <?MarkedContent page="1" ?>О краеугольных [принципах] То­
   <?MarkedContent page="1" ?>ры, имеется ввиду, которые [есть] ос­
   <?MarkedContent page="1" ?>новы и столпы на которых дом Б-жий 
   <?MarkedContent page="1" ?>опирается/нахон, и с существованием 
   <?MarkedContent page="1" ?>их может быть представлено существо­
   <?MarkedContent page="1" ?>вание Торы упорядоченной от Него, 
   <?MarkedContent page="1" ?>благословенного, и если бы было пред­
   <?MarkedContent page="1" ?>ставлено отсутствие одного из них — 
   <?MarkedContent page="1" ?>упадет Тора в общем, [Б-же] упаси.
  </text>
 </text-unit>
</Document>
