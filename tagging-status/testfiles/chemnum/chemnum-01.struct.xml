     Layout:TextAlign="Justify"
     rolemaps-to="P"
    >
   <?MarkedContent page="1" ?>Compounds 1 and 2 are declared and can be used any time: 
   <Link xmlns="http://iso.org/pdf2/ssn"
      id="ID.00007"
     >
    <?MarkedContent page="1" ?>1
    <?ReferencedObject type="Annot" page="1" ?>
   </Link>
   <?MarkedContent page="1" ?>. No pre-declaring is necessary. Compounds like 3 are numbered in the order they appear in the text.
  </text>
 </text-unit>
