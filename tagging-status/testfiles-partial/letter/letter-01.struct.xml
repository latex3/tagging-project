    <text xmlns="https://www.latex-project.org/ns/dflt"
       id="ID.031"
       xmlns:Layout="http://iso.org/pdf/ssn/Layout"
       Layout:TextAlign="Justify"
       rolemaps-to="P"
      >
     <?MarkedContent page="1" ?>I am writing to you on behalf of the Wikipedia project (http://www.wikipedia.org/), an endeavour to build a fully-fledged multilingual encyclopaedia in an entirely open manner, to ask for permission to use your copyrighted material.
    </text>
   </text-unit>
   <text-unit xmlns="https://www.latex-project.org/ns/dflt"
