            id="ID.0080"
            xmlns:Layout="http://iso.org/pdf/ssn/Layout"
            Layout:TextAlign="Justify"
            rolemaps-to="P"
           >
          <?MarkedContent page="2" ?>S. Ferry and E. K. Pedersen, Epsilon surgery theory I, Novikov conjectures, index theo
          <?MarkedContent page="2" ?>rems and rigidity, vol. 2 (Oberwolfach, 1993), 1995, pp. 167–226. MR97g:57044
