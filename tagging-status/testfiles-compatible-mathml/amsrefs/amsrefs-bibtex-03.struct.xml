       >
      <?MarkedContent page="2" ?>Actually [
      <Link xmlns="http://iso.org/pdf2/ssn"
         id="ID.0086"
        >
       <?MarkedContent page="2" ?>5
       <?ReferencedObject type="Annot" page="2" ?>
      </Link>
      <?MarkedContent page="2" ?>, (5.2)] is for 
      <Formula xmlns="http://iso.org/pdf2/ssn"
         id="ID.0087"
         title="math"
         af="mathml-12.xml tag-AFfile12.tex"
         xmlns:Layout="http://iso.org/pdf/ssn/Layout"
         Layout:Placement="Inline"
        >
        <AssociatedFile name="mathml-12.xml" xmlns="">
        <math xmlns="http://www.w3.org/1998/Math/MathML"> <mi>𝑚</mi> <mo lspace="0.278em" rspace="0.278em">≥</mo> <mn>7</mn> </math>
        </AssociatedFile>
        <AssociatedFile name="tag-AFfile12.tex" xmlns="">
        $m\geq 7$
        </AssociatedFile>
       <?MarkedContent page="2" ?>𝑚≥7
      </Formula>
      <?MarkedContent page="2" ?>, but we can improve to 
      <Formula xmlns="http://iso.org/pdf2/ssn"
         id="ID.0088"
         title="math"
         af="mathml-13.xml tag-AFfile13.tex"
         xmlns:Layout="http://iso.org/pdf/ssn/Layout"
         Layout:Placement="Inline"
        >
        <AssociatedFile name="mathml-13.xml" xmlns="">
        <math xmlns="http://www.w3.org/1998/Math/MathML"> <mi>𝑚</mi> <mo lspace="0.278em" rspace="0.278em">≥</mo> <mn>6</mn> </math>
        </AssociatedFile>
        <AssociatedFile name="tag-AFfile13.tex" xmlns="">
        $m\geq 6$
        </AssociatedFile>
       <?MarkedContent page="2" ?>𝑚≥6
      </Formula>
      <?MarkedContent page="2" ?> by a slight variation of the proof as described below.
     </text>
