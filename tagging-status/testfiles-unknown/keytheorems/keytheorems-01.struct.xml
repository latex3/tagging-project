       Layout:TextAlign="Justify"
       rolemaps-to="P"
      >
     <?MarkedContent page="2" ?>Admitting reflection and rotation, a three-legged pig 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00165"
        title="math"
        af="tag-AFfile53.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="2" ?>𝑃
     </Formula>
     <?MarkedContent page="2" ?> is capable of standing on the corners of a triangle 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00166"
        title="math"
        af="tag-AFfile54.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="2" ?>𝑇
