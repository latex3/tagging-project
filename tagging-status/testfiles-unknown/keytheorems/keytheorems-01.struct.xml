   </section-number>
   <?MarkedContent page="2" ?>Test of number-swapping
  </section>
  <text-unit xmlns="https://www.latex-project.org/ns/dflt"
     id="ID.00115"
     rolemaps-to="Part"
    >
   <text xmlns="https://www.latex-project.org/ns/dflt"
      id="ID.00116"
      xmlns:Layout="http://iso.org/pdf/ssn/Layout"
      Layout:TextAlign="Justify"
      rolemaps-to="P"
     >
    <?MarkedContent page="2" ?>This is a repeat of the first section but with numbers in theorem heads swapped to the left.
   </text>
  </text-unit>
  <text-unit xmlns="https://www.latex-project.org/ns/dflt"
     id="ID.00117"
     rolemaps-to="Part"
    >
   <text xmlns="https://www.latex-project.org/ns/dflt"
      id="ID.00118"
      xmlns:Layout="http://iso.org/pdf/ssn/Layout"
      Layout:TextAlign="Justify"
      rolemaps-to="P"
     >
    <?MarkedContent page="2" ?>Ahlfors’ Lemma gives the principal criterion for obtaining lower bounds on the Kobayashi metric.
   </text>
  </text-unit>
  <theorem-like xmlns="https://www.latex-project.org/ns/dflt"
     id="ID.00119"
     rolemaps-to="Sect"
    >
   <Caption xmlns="http://iso.org/pdf2/ssn"
      id="ID.00120"
     >
    <?MarkedContent page="2" ?>Ahlfors’ Lemma
    <?MarkedContent page="2" ?>.
   </Caption>
   <text-unit xmlns="https://www.latex-project.org/ns/dflt"
      id="ID.00121"
      rolemaps-to="Part"
     >
    <text xmlns="https://www.latex-project.org/ns/dflt"
       id="ID.00122"
       xmlns:Layout="http://iso.org/pdf/ssn/Layout"
       Layout:TextAlign="Justify"
       rolemaps-to="P"
      >
     <?MarkedContent page="2" ?>Let 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00123"
        title="math"
        af="tag-AFfile29.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="2" ?>𝑑𝑠2=ℎ(𝑧)|𝑑𝑧|2
     </Formula>
     <?MarkedContent page="2" ?> be a Hermitian pseudo-metric on 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00124"
        title="math"
        af="tag-AFfile30.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="2" ?>D𝑟
     </Formula>
     <?MarkedContent page="2" ?>, 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00125"
        title="math"
        af="tag-AFfile31.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="2" ?>ℎ∈𝐶2(D𝑟)
     </Formula>
     <?MarkedContent page="2" ?>, with 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00126"
        title="math"
        af="tag-AFfile32.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="2" ?>𝜔
     </Formula>
     <?MarkedContent page="2" ?> the associated 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00127"
        title="math"
        af="tag-AFfile33.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="2" ?>(1,1)
     </Formula>
     <?MarkedContent page="2" ?>-form. If 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00128"
        title="math"
        af="tag-AFfile34.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="2" ?>Ric𝜔≥𝜔
     </Formula>
     <?MarkedContent page="2" ?> on 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00129"
        title="math"
        af="tag-AFfile35.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="2" ?>D𝑟
     </Formula>
     <?MarkedContent page="2" ?>, then 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00130"
        title="math"
        af="tag-AFfile36.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="2" ?>𝜔≤𝜔𝑟
     </Formula>
     <?MarkedContent page="2" ?>on all of 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00131"
        title="math"
        af="tag-AFfile37.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="2" ?>D𝑟
     </Formula>
     <?MarkedContent page="2" ?> (or equivalently, 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00132"
        title="math"
        af="tag-AFfile38.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="2" ?>𝑑𝑠2≤𝑑𝑠2𝑟
     </Formula>
     <?MarkedContent page="2" ?>).
    </text>
   </text-unit>
  </theorem-like>
  <theorem-like xmlns="https://www.latex-project.org/ns/dflt"
     id="ID.00133"
     rolemaps-to="Sect"
    >
   <Caption xmlns="http://iso.org/pdf2/ssn"
      id="ID.00134"
     >
    <Lbl xmlns="http://iso.org/pdf2/ssn"
       id="ID.00135"
      >
     <?MarkedContent page="2" ?>4.1 
    </Lbl>
    <?MarkedContent page="2" ?>Lemma
    <?MarkedContent page="2" ?> (negatively curved families)
    <?MarkedContent page="2" ?>.
   </Caption>
   <text-unit xmlns="https://www.latex-project.org/ns/dflt"
      id="ID.00136"
      rolemaps-to="Part"
     >
    <text xmlns="https://www.latex-project.org/ns/dflt"
       id="ID.00137"
       xmlns:Layout="http://iso.org/pdf/ssn/Layout"
       Layout:TextAlign="Justify"
       rolemaps-to="P"
      >
     <?MarkedContent page="2" ?>Let 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00138"
        title="math"
        af="tag-AFfile39.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="2" ?>{𝑑𝑠21,…,𝑑𝑠2𝑘}
     </Formula>
     <?MarkedContent page="2" ?> be a negatively curved family of metrics on 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00139"
        title="math"
        af="tag-AFfile40.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="2" ?>D𝑟
     </Formula>
     <?MarkedContent page="2" ?>, with associated forms 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00140"
        title="math"
        af="tag-AFfile41.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="2" ?>𝜔1
     </Formula>
     <?MarkedContent page="2" ?>, …, 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00141"
        title="math"
        af="tag-AFfile42.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="2" ?>𝜔𝑘
     </Formula>
     <?MarkedContent page="2" ?>. Then 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00142"
        title="math"
        af="tag-AFfile43.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="2" ?>𝜔𝑖≤𝜔𝑟
     </Formula>
     <?MarkedContent page="2" ?> for all 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00143"
        title="math"
        af="tag-AFfile44.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="2" ?>𝑖
     </Formula>
     <?MarkedContent page="2" ?>.
    </text>
   </text-unit>
  </theorem-like>
  <text-unit xmlns="https://www.latex-project.org/ns/dflt"
     id="ID.00144"
     rolemaps-to="Part"
    >
   <text xmlns="https://www.latex-project.org/ns/dflt"
      id="ID.00145"
      xmlns:Layout="http://iso.org/pdf/ssn/Layout"
      Layout:TextAlign="Justify"
      rolemaps-to="P"
     >
    <?MarkedContent page="2" ?>Then our main theorem:
   </text>
  </text-unit>
  <theorem-like xmlns="https://www.latex-project.org/ns/dflt"
     id="ID.00146"
     rolemaps-to="Sect"
    >
   <Caption xmlns="http://iso.org/pdf2/ssn"
      id="ID.00147"
     >
    <Lbl xmlns="http://iso.org/pdf2/ssn"
       id="ID.00148"
      >
     <?MarkedContent page="2" ?>4.2 
    </Lbl>
    <?MarkedContent page="2" ?>Theorem
    <?MarkedContent page="2" ?>.
   </Caption>
   <text-unit xmlns="https://www.latex-project.org/ns/dflt"
      id="ID.00149"
      rolemaps-to="Part"
     >
    <text xmlns="https://www.latex-project.org/ns/dflt"
       id="ID.00150"
       xmlns:Layout="http://iso.org/pdf/ssn/Layout"
       Layout:TextAlign="Justify"
       rolemaps-to="P"
      >
     <?MarkedContent page="2" ?>Let 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00151"
        title="math"
        af="tag-AFfile45.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="2" ?>𝑑max
     </Formula>
     <?MarkedContent page="2" ?> and 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00152"
        title="math"
        af="tag-AFfile46.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="2" ?>𝑑min
     </Formula>
     <?MarkedContent page="2" ?> be the maximum, resp. minimum distance between any two adjacent vertices of a quadrilateral 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00153"
        title="math"
        af="tag-AFfile47.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="2" ?>𝑄
     </Formula>
     <?MarkedContent page="2" ?>. Let 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00154"
        title="math"
        af="tag-AFfile48.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="2" ?>𝜎
     </Formula>
     <?MarkedContent page="2" ?> be the diagonal pigspan of a pig 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00155"
        title="math"
        af="tag-AFfile49.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="2" ?>𝑃
     </Formula>
     <?MarkedContent page="2" ?> with four legs. Then 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00156"
        title="math"
        af="tag-AFfile50.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="2" ?>𝑃
     </Formula>
     <?MarkedContent page="2" ?> is capable of standing on the corners of 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00157"
        title="math"
        af="tag-AFfile51.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="2" ?>𝑄
     </Formula>
     <?MarkedContent page="2" ?> iff
    </text>
    <Formula xmlns="http://iso.org/pdf2/ssn"
       id="ID.00158"
       title="equation"
       af="tag-AFfile52.tex"
       xmlns:Layout="http://iso.org/pdf/ssn/Layout"
       Layout:Placement="Block"
      >
     <?MarkedContent page="2" ?>𝜎≥√𝑑2max+𝑑2min.
     <Lbl xmlns="http://iso.org/pdf2/ssn"
        id="ID.00159"
       >
      <?MarkedContent page="2" ?>(2)
     </Lbl>
     <?MarkedContent page="2" ?>
    </Formula>
   </text-unit>
  </theorem-like>
