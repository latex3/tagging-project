   </section-number>
   <?MarkedContent page="1" ?>Test of standard theorem styles
  </section>
  <text-unit xmlns="https://www.latex-project.org/ns/dflt"
     id="ID.00013"
     rolemaps-to="Part"
    >
   <text xmlns="https://www.latex-project.org/ns/dflt"
      id="ID.00014"
      xmlns:Layout="http://iso.org/pdf/ssn/Layout"
      Layout:TextAlign="Justify"
      rolemaps-to="P"
     >
    <?MarkedContent page="1" ?>Ahlfors’ Lemma gives the principal criterion for obtaining lower bounds on the Kobayashi metric.
   </text>
  </text-unit>
  <theorem-like xmlns="https://www.latex-project.org/ns/dflt"
     id="ID.00015"
     rolemaps-to="Sect"
    >
   <Caption xmlns="http://iso.org/pdf2/ssn"
      id="ID.00016"
     >
    <?MarkedContent page="1" ?>Ahlfors’ Lemma
    <?MarkedContent page="1" ?>.
   </Caption>
   <text-unit xmlns="https://www.latex-project.org/ns/dflt"
      id="ID.00017"
      rolemaps-to="Part"
     >
    <text xmlns="https://www.latex-project.org/ns/dflt"
       id="ID.00018"
       xmlns:Layout="http://iso.org/pdf/ssn/Layout"
       Layout:TextAlign="Justify"
       rolemaps-to="P"
      >
     <?MarkedContent page="1" ?>Let 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00019"
        title="math"
        af="tag-AFfile1.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="1" ?>𝑑𝑠2=ℎ(𝑧)|𝑑𝑧|2
     </Formula>
     <?MarkedContent page="1" ?> be a Hermitian pseudo-metric on 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00020"
        title="math"
        af="tag-AFfile2.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="1" ?>D𝑟
     </Formula>
     <?MarkedContent page="1" ?>, 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00021"
        title="math"
        af="tag-AFfile3.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="1" ?>ℎ∈𝐶2(D𝑟)
     </Formula>
     <?MarkedContent page="1" ?>, with 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00022"
        title="math"
        af="tag-AFfile4.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="1" ?>𝜔
     </Formula>
     <?MarkedContent page="1" ?> the associated 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00023"
        title="math"
        af="tag-AFfile5.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="1" ?>(1,1)
     </Formula>
     <?MarkedContent page="1" ?>-form. If 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00024"
        title="math"
        af="tag-AFfile6.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="1" ?>Ric𝜔≥𝜔
     </Formula>
     <?MarkedContent page="1" ?> on 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00025"
        title="math"
        af="tag-AFfile7.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="1" ?>D𝑟
     </Formula>
     <?MarkedContent page="1" ?>, then 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00026"
        title="math"
        af="tag-AFfile8.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="1" ?>𝜔≤𝜔𝑟
     </Formula>
     <?MarkedContent page="1" ?>on all of 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00027"
        title="math"
        af="tag-AFfile9.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="1" ?>D𝑟
     </Formula>
     <?MarkedContent page="1" ?> (or equivalently, 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00028"
        title="math"
        af="tag-AFfile10.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="1" ?>𝑑𝑠2≤𝑑𝑠2𝑟
     </Formula>
     <?MarkedContent page="1" ?>).
    </text>
   </text-unit>
  </theorem-like>
  <theorem-like xmlns="https://www.latex-project.org/ns/dflt"
     id="ID.00029"
     rolemaps-to="Sect"
    >
   <Caption xmlns="http://iso.org/pdf2/ssn"
      id="ID.00030"
     >
    <?MarkedContent page="1" ?>Lemma
    <Lbl xmlns="http://iso.org/pdf2/ssn"
       id="ID.00031"
      >
     <?MarkedContent page="1" ?> 1.1
    </Lbl>
    <?MarkedContent page="1" ?>  (negatively curved families)
    <?MarkedContent page="1" ?>.
   </Caption>
   <text-unit xmlns="https://www.latex-project.org/ns/dflt"
      id="ID.00032"
      rolemaps-to="Part"
     >
    <text xmlns="https://www.latex-project.org/ns/dflt"
       id="ID.00033"
       xmlns:Layout="http://iso.org/pdf/ssn/Layout"
       Layout:TextAlign="Justify"
       rolemaps-to="P"
      >
     <?MarkedContent page="1" ?>Let 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00034"
        title="math"
        af="tag-AFfile11.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="1" ?>{𝑑𝑠21,…,𝑑𝑠2𝑘}
     </Formula>
     <?MarkedContent page="1" ?> be a negatively curved family of metrics on 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00035"
        title="math"
        af="tag-AFfile12.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="1" ?>D𝑟
     </Formula>
     <?MarkedContent page="1" ?>, with associated forms 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00036"
        title="math"
        af="tag-AFfile13.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="1" ?>𝜔1
     </Formula>
     <?MarkedContent page="1" ?>, …, 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00037"
        title="math"
        af="tag-AFfile14.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="1" ?>𝜔𝑘
     </Formula>
     <?MarkedContent page="1" ?>. Then 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00038"
        title="math"
        af="tag-AFfile15.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="1" ?>𝜔𝑖≤𝜔𝑟
     </Formula>
     <?MarkedContent page="1" ?> for all 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00039"
        title="math"
        af="tag-AFfile16.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="1" ?>𝑖
     </Formula>
     <?MarkedContent page="1" ?>.
    </text>
   </text-unit>
  </theorem-like>
  <text-unit xmlns="https://www.latex-project.org/ns/dflt"
     id="ID.00040"
     rolemaps-to="Part"
    >
   <text xmlns="https://www.latex-project.org/ns/dflt"
      id="ID.00041"
      xmlns:Layout="http://iso.org/pdf/ssn/Layout"
      Layout:TextAlign="Justify"
      rolemaps-to="P"
     >
    <?MarkedContent page="1" ?>Then our main theorem:
   </text>
  </text-unit>
  <theorem-like xmlns="https://www.latex-project.org/ns/dflt"
     id="ID.00042"
     rolemaps-to="Sect"
    >
   <Caption xmlns="http://iso.org/pdf2/ssn"
      id="ID.00043"
     >
    <?MarkedContent page="1" ?>Theorem
    <Lbl xmlns="http://iso.org/pdf2/ssn"
       id="ID.00044"
      >
     <?MarkedContent page="1" ?> 1.2
    </Lbl>
    <?MarkedContent page="1" ?>.
   </Caption>
   <text-unit xmlns="https://www.latex-project.org/ns/dflt"
      id="ID.00045"
      rolemaps-to="Part"
     >
    <text xmlns="https://www.latex-project.org/ns/dflt"
       id="ID.00046"
       xmlns:Layout="http://iso.org/pdf/ssn/Layout"
       Layout:TextAlign="Justify"
       rolemaps-to="P"
      >
     <?MarkedContent page="1" ?> Let 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00047"
        title="math"
        af="tag-AFfile17.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="1" ?>𝑑max
     </Formula>
     <?MarkedContent page="1" ?> and 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00048"
        title="math"
        af="tag-AFfile18.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="1" ?>𝑑min
     </Formula>
     <?MarkedContent page="1" ?> be the maximum, resp. minimum distance between any two adjacent vertices of a quadrilateral 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00049"
        title="math"
        af="tag-AFfile19.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="1" ?>𝑄
     </Formula>
     <?MarkedContent page="1" ?>. Let 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00050"
        title="math"
        af="tag-AFfile20.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="1" ?>𝜎
     </Formula>
     <?MarkedContent page="1" ?> be the diagonal pigspan of a pig 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00051"
        title="math"
        af="tag-AFfile21.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="1" ?>𝑃
     </Formula>
     <?MarkedContent page="1" ?> with four legs. Then 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00052"
        title="math"
        af="tag-AFfile22.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="1" ?>𝑃
     </Formula>
     <?MarkedContent page="1" ?> is capable of standing on the corners of 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00053"
        title="math"
        af="tag-AFfile23.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="1" ?>𝑄
     </Formula>
     <?MarkedContent page="1" ?> iff
    </text>
    <Formula xmlns="http://iso.org/pdf2/ssn"
       id="ID.00054"
       title="equation"
       af="tag-AFfile24.tex"
       xmlns:Layout="http://iso.org/pdf/ssn/Layout"
       Layout:Placement="Block"
      >
     <?MarkedContent page="1" ?>𝜎≥√𝑑2max+𝑑2min.
     <Lbl xmlns="http://iso.org/pdf2/ssn"
        id="ID.00055"
       >
      <?MarkedContent page="1" ?>(1)
     </Lbl>
     <?MarkedContent page="1" ?>
    </Formula>
   </text-unit>
  </theorem-like>
  <theorem-like xmlns="https://www.latex-project.org/ns/dflt"
     id="ID.00056"
     rolemaps-to="Sect"
    >
   <Caption xmlns="http://iso.org/pdf2/ssn"
      id="ID.00057"
     >
    <?MarkedContent page="1" ?>Corollary
    <Lbl xmlns="http://iso.org/pdf2/ssn"
       id="ID.00058"
      >
     <?MarkedContent page="1" ?> 1.3
    </Lbl>
    <?MarkedContent page="1" ?>.
   </Caption>
   <text-unit xmlns="https://www.latex-project.org/ns/dflt"
      id="ID.00059"
      rolemaps-to="Part"
     >
    <text xmlns="https://www.latex-project.org/ns/dflt"
       id="ID.00060"
       xmlns:Layout="http://iso.org/pdf/ssn/Layout"
       Layout:TextAlign="Justify"
       rolemaps-to="P"
      >
     <?MarkedContent page="1" ?>Admitting reflection and rotation, a three-legged pig 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00061"
        title="math"
        af="tag-AFfile25.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="1" ?>𝑃
     </Formula>
     <?MarkedContent page="1" ?> is capable of standing on the corners of a triangle 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00062"
        title="math"
        af="tag-AFfile26.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="1" ?>𝑇
     </Formula>
     <?MarkedContent page="1" ?> iff (??) holds.
    </text>
   </text-unit>
  </theorem-like>
  <theorem-like xmlns="https://www.latex-project.org/ns/dflt"
     id="ID.00063"
     rolemaps-to="Sect"
    >
   <Caption xmlns="http://iso.org/pdf2/ssn"
      id="ID.00064"
     >
    <?MarkedContent page="1" ?>Remark
    <?MarkedContent page="1" ?>.
   </Caption>
   <text-unit xmlns="https://www.latex-project.org/ns/dflt"
      id="ID.00065"
      rolemaps-to="Part"
     >
    <text xmlns="https://www.latex-project.org/ns/dflt"
       id="ID.00066"
       xmlns:Layout="http://iso.org/pdf/ssn/Layout"
       Layout:TextAlign="Justify"
       rolemaps-to="P"
      >
     <?MarkedContent page="1" ?>As two-legged pigs generally fall over, the case of a polygon of order 
     <Formula xmlns="http://iso.org/pdf2/ssn"
        id="ID.00067"
        title="math"
        af="tag-AFfile27.tex"
        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:Placement="Inline"
       >
      <?MarkedContent page="1" ?>2
     </Formula>
     <?MarkedContent page="1" ?>is uninteresting.
    </text>
   </text-unit>
  </theorem-like>
