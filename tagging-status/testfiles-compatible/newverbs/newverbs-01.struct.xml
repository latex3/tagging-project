        xmlns:Layout="http://iso.org/pdf/ssn/Layout"
        Layout:TextAlign="Justify"
        rolemaps-to="P"
       >
      <?MarkedContent page="1" ?>This hides 
      <Code xmlns="http://iso.org/pdf/ssn"
         id="ID.027"
        >
       <?MarkedContent page="1" ?>%&amp;␣$^_
      </Code>
      <?MarkedContent page="1" ?> within 
      <Code xmlns="http://iso.org/pdf/ssn"
         id="ID.028"
        >
       <?MarkedContent page="1" ?>\foo
      </Code>
      <?MarkedContent page="1" ?> and 
      <Code xmlns="http://iso.org/pdf/ssn"
         id="ID.029"
        >
       <?MarkedContent page="1" ?>\baz
      </Code>
      <?MarkedContent page="1" ?> so that it can be used in the heading. Warning: 
      <Code xmlns="http://iso.org/pdf/ssn"
         id="ID.030"
        >
       <?MarkedContent page="1" ?>%&amp;␣$^_
      </Code>
      <?MarkedContent page="1" ?> is equal to %&amp; $^_ but not to %&amp; $^_!
     </text>
